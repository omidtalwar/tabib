# Tabib Pharmacy portal — static SPA-ish routing under /db/.
# Routing is client-side via hash (#/p/{id}/...), so we only need:
#  - a clean default document,
#  - never expose the .htaccess itself,
#  - let real files (js/css/png) serve directly.

DirectoryIndex index.html

<IfModule mod_mime.c>
  AddType application/manifest+json .webmanifest
</IfModule>

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /db/

  # Serve existing files/dirs as-is.
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Anything else under /db/ falls back to the login document.
  # (Authenticated views live in app.html and are reached after sign-in.)
  RewriteRule ^ index.html [L]
</IfModule>

<Files ".htaccess">
  Require all denied
</Files>

# During active development, always revalidate JS/CSS/HTML so updated ES modules
# can't go stale and break imports (e.g. a cached session.js missing a new
# export). Tighten to a longer max-age once the portal stabilizes for production.
<IfModule mod_headers.c>
  # Force-override the host's static-asset caching (it sets max-age=14400 on JS,
  # which serves stale ES modules). unset removes any prior value; `always set`
  # wins over mod_expires/server config so updated modules load immediately.
  <FilesMatch "\.(js|mjs|css|html)$">
    Header unset Cache-Control
    Header always set Cache-Control "no-store, no-cache, must-revalidate, max-age=0"
    Header unset Expires
    Header always set Expires "0"
    Header unset Pragma
    Header always set Pragma "no-cache"
  </FilesMatch>

  # Allow Firebase Google sign-in popups to keep their opener relationship.
  Header set Cross-Origin-Opener-Policy "same-origin-allow-popups"
</IfModule>
<IfModule mod_expires.c>
  # Make sure mod_expires doesn't re-add a long max-age for scripts/styles.
  ExpiresActive On
  ExpiresByType application/javascript "access plus 0 seconds"
  ExpiresByType text/javascript "access plus 0 seconds"
  ExpiresByType text/css "access plus 0 seconds"
</IfModule>
