rules_version = '2';

// Tabib Pharmacy — INTERIM rules (D3). A pharmacy's data is accessible to its
// MEMBERS: the OWNER (pharmacies/{id}.ownerUid == uid) or a user whose custom
// claim pharmacyId == {id}. Owners can read/list ALL pharmacies they own, which
// powers the portal's pharmacy switcher.
//
// Interim notes (until the app is rebuilt to the secure flow):
//  - Plaintext `password` is still ALLOWED here so the shipped app keeps working;
//    tighten (forbid password, drop owner fallback) once the app moves creation
//    server-side and stops writing passwords.
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() { return request.auth != null; }
    function claim()    { return request.auth.token.pharmacyId; }
    function ownerOf(pid) {
      return get(/databases/$(database)/documents/pharmacies/$(pid)).data.ownerUid == request.auth.uid;
    }

    match /pharmacies/{pharmacyId} {
      // Doc read uses resource.data directly (no get()) so an owner can LIST
      // their pharmacies with where('ownerUid','==',uid).
      allow read: if signedIn() &&
        (resource.data.ownerUid == request.auth.uid || claim() == pharmacyId);

      allow create: if signedIn() && request.resource.data.ownerUid == request.auth.uid;
      allow update: if signedIn()
        && (resource.data.ownerUid == request.auth.uid || claim() == pharmacyId)
        && request.resource.data.ownerUid == resource.data.ownerUid;
      allow delete: if false;

      // Sub-collections (drugs, sales, patients, prescriptions, suppliers, ...).
      match /{sub=**} {
        allow read, write: if signedIn() &&
          (claim() == pharmacyId || ownerOf(pharmacyId));
      }
    }

    // Per-user settings keyed by uid (app writes its own).
    match /pharmacy_settings/{uid} {
      allow read, write: if signedIn() && request.auth.uid == uid;
    }

    // user_practices link doc — a user may read/write only their own link.
    match /user_practices/{uid} {
      allow read, write: if signedIn() && request.auth.uid == uid;
    }

    // Deny everything else (incl. legacy top-level pharmacy_* paths — D4 pending).
    match /{document=**} { allow read, write: if false; }
  }
}
